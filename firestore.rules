rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow get: if signedIn() && adminId == request.auth.uid;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /users/{uid} {
      allow get: if isAdmin() || (signedIn() && uid == request.auth.uid);
      allow list: if isAdmin();

      allow create: if isAdmin() || (
        signedIn() && uid == request.auth.uid &&
        (!('banned' in request.resource.data) || request.resource.data.banned == false)
      );

      allow update: if isAdmin() || (
        signedIn() && uid == request.auth.uid &&
        (!('banned' in request.resource.data) || request.resource.data.banned == resource.data.banned)
      );

      allow delete: if isAdmin();
    }
  }
}
